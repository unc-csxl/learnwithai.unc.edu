APP_NAME=learnwithai
ENVIRONMENT=development

# Optional overrides. These defaults match the dev container setup.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/learnwithai
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

DB_ECHO=false
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# These defaults only work if the target endpoint exposes this deployment.
OPENAI_MODEL=gpt-5-mini
OPENAI_ENDPOINT=https://azureaiapi.cloud.unc.edu
OPENAI_API_VERSION=2025-04-01-preview

# Set this to a real Azure OpenAI-compatible subscription key.
OPENAI_API_KEY=<set-your-azure-openai-subscription-key>