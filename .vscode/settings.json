{
    "files.exclude": {
        "api": true,
        "frontend": true,
        "worker": true,
        "packages": true,
        "infra": true
    },
    "python-envs.pythonProjects": [
        {
            "path": ".",
            "envManager": "ms-python.python:venv",
            "packageManager": "ms-python.python:pip",
        }
    ],
    "python.defaultInterpreterPath": "/workspaces/learnwithai/.venv/bin/python",
    "python.analysis.extraPaths": [
        "/workspaces/learnwithai/api/src",
        "/workspaces/learnwithai/packages/learnwithai-core/src",
        "/workspaces/learnwithai/packages/learnwithai-jobqueue/src"
    ],
    "python.terminal.useEnvFile": true,
    "python.testing.pytestEnabled": false,
    "python.testing.unittestEnabled": false,
    "python.testing.cwd": "/workspaces/learnwithai",
}