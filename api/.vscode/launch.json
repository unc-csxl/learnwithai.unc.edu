{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "api.main:app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000"
      ],
      "cwd": "${workspaceFolder:api}",
      "env": {
        "PYTHONPATH": "${workspaceFolder:api}/src"
      },
      "justMyCode": true
    }
  ]
}